{
    "protected_dirs": [
        "venv",
        ".venv", 
        "env",
        "node_modules"
    ],
    "max_file_size_mb": 100,
    "exclude_patterns": [
        "**/*.py",
        "**/*.cpp", 
        "**/*.h",
        "**/*.hpp",
        "**/*.c",
        "**/src/**",
        "**/include/**",
        "**/lib/**"
    ]
}
